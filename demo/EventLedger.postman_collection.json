        },
        {
          "name": "8c. T1 CREDIT +100 (earliest last)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created (201) or replayed (200)', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});"
                ],
