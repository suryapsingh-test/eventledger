          }
        }
      ]
    },
    {
      "name": "C. Error scenarios",
      "item": [
        {
          "name": "9. Validation — negative amount (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('traceId present in ProblemDetails', function () {",
                  "  pm.expect(pm.response.json().traceId).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-bad-9001\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": -5.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-06-26T16:10:00Z\"\n}"
            },
            "url": "{{gatewayUrl}}/events"
