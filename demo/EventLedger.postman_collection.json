          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-ooo-t1\",\n  \"accountId\": \"{{outOfOrderAcct}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 100.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-06-26T16:00:00Z\"\n}"
            },
            "url": "{{gatewayUrl}}/events"
          }
        },
        {
          "name": "8d. Balance (expect 120.00)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Balance is 120.00', function () {",
                  "  pm.expect(pm.response.json().balance).to.eql(120);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{accountUrl}}/accounts/{{outOfOrderAcct}}/balance"
          }
        },
        {
          "name": "8e. List events (sorted by eventTimestamp)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/events?account={{outOfOrderAcct}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["events"],
              "query": [{ "key": "account", "value": "{{outOfOrderAcct}}" }]
