          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-ooo-t2\",\n  \"accountId\": \"{{outOfOrderAcct}}\",\n  \"type\": \"DEBIT\",\n  \"amount\": 30.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-06-26T17:00:00Z\"\n}"
