    },
    {
      "name": "F. Optional — Graceful degradation",
      "description": "**Prerequisites:** Complete folder **A** first (Gateway must have persisted events).\n\n**Stop Account Service:**\n```\ndocker compose stop account-service\n```\nOr stop the local process on port 8081.\n\n**Restart when done:**\n```\ndocker compose start account-service\n```",
      "item": [
        {
          "name": "F1. POST /events while Account down (503)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 503 Service Unavailable', function () {",
                  "  pm.response.to.have.status(503);",
                  "});",
                  "pm.test('ProblemDetails title', function () {",
                  "  pm.expect(pm.response.json().title).to.eql('Account Service unavailable');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{degradeEventId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 99.00,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-06-26T20:00:00Z\",\n  \"metadata\": { \"source\": \"degradation-demo\" }\n}"
            },
            "url": "{{gatewayUrl}}/events"
          }
        },
        {
          "name": "F2. Event not persisted (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Degraded POST was not stored', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gatewayUrl}}/events/{{degradeEventId}}"
          }
        },
        {
          "name": "F3. GET stored event still works (Gateway local DB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200 from Gateway local data', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Original event from section A', function () {",
                  "  pm.expect(pm.response.json().eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gatewayUrl}}/events/{{creditEventId}}"
          }
        },
        {
          "name": "F4. Balance query fails (connection refused — manual)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{accountUrl}}/accounts/{{accountId}}/balance",
            "description": "Expect **connection refused** or request failure — Account Service is stopped. No automated assertion (Postman cannot connect)."
          }
        }
      ]
    }
  ]
}

