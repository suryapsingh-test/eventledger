{
  "ConnectionStrings": {
    "Default": "Data Source=gateway.db"
  },
  "AccountService": {
    "BaseUrl": "http://localhost:8081",
    "Resilience": {
      "MaxRetryAttempts": 3,
      "RetryBaseDelayMs": 200,
      "TimeoutSeconds": 5,
      "CircuitBreakerFailures": 5,
      "CircuitBreakerBreakSeconds": 30
    }
  },
  "Gateway": {
    "Inbound": {
      "ConcurrencyLimit": 100,
      "ConcurrencyQueueLimit": 50,
      "PerClientWritePermitLimit": 300,
      "PerClientWriteWindowSeconds": 60
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;event-gateway;account-service"
}
